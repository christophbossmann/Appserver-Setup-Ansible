{# ============================================================
   Build the final environment dict via combine.
   - n8n_env_base:     role defaults, always present
   - n8n_env_public:   reverse-proxy vars, only when hostname set
   - n8n_env_optional: encryption key etc., only when non-empty
   - n8n_extra_env:    user overrides from group_vars/all/n8n.yml (wins over all)
   ============================================================ #}

{% set computed_public_url = n8n_public_url if n8n_public_url | length > 0
                             else n8n_public_protocol ~ '://' ~ n8n_public_hostname ~ '/' %}

{% set n8n_env_base = {
  'DB_TYPE':                               'postgresdb',
  'DB_POSTGRESDB_HOST':                    n8n_db_host,
  'DB_POSTGRESDB_PORT':                    n8n_db_port | string,
  'DB_POSTGRESDB_USER':                    n8n_db_user,
  'DB_POSTGRESDB_PASSWORD':                n8n_db_password,
  'DB_POSTGRESDB_DATABASE':                n8n_db_name,
  'GENERIC_TIMEZONE':                      n8n_timezone,
  'TZ':                                    n8n_timezone,
  'N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS': 'true',
  'N8N_RUNNERS_ENABLED':                   'true',
  'N8N_SECURE_COOKIE':                     n8n_secure_cookie | bool | ternary('true', 'false')
} %}

{% set n8n_env_public = {} %}
{% if n8n_public_hostname | length > 0 or n8n_public_url | length > 0 %}
{% set n8n_env_public = {
  'N8N_HOST':            n8n_public_hostname,
  'N8N_PROTOCOL':        n8n_public_protocol,
  'WEBHOOK_URL':         computed_public_url | regex_replace('/+$', '') ~ '/',
  'N8N_EDITOR_BASE_URL': computed_public_url | regex_replace('/+$', ''),
  'N8N_PROXY_HOPS':      n8n_proxy_hops | string
} %}
{% endif %}

{% set n8n_env_optional = {} %}
{% if n8n_encryption_key | length > 0 %}
{% set n8n_env_optional = {'N8N_ENCRYPTION_KEY': n8n_encryption_key} %}
{% endif %}

{# Final merge: base → public → optional → user (user wins) #}
{% set n8n_env_final = n8n_env_base
   | combine(n8n_env_public)
   | combine(n8n_env_optional)
   | combine(n8n_extra_env) %}

services:
  n8n:
    image: {{ n8n_image }}
    container_name: n8n
    restart: unless-stopped
    ports:
{% if n8n_bind_address | length > 0 %}
      - "{{ n8n_bind_address }}:{{ n8n_port }}:5678"
{% else %}
      - "{{ n8n_port }}:5678"
{% endif %}
    volumes:
      - {{ n8n_data_dir }}:/home/node/.n8n
      - {{ n8n_brain_dir }}:/files
    environment:
{% for key, value in n8n_env_final.items() %}
      - {{ key }}={{ value }}
{% endfor %}
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:5678/healthz || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5

{% if n8n_webdav_enabled %}
  n8n-webdav:
    image: {{ rclone_image }}
    container_name: n8n-webdav
    restart: unless-stopped
    user: "1000:1000"
    command: >
      serve webdav /data
      --addr :8888
      --user {{ n8n_webdav_user }}
      --pass {{ n8n_webdav_password }}
      --dir-cache-time {{ n8n_webdav_cachetime }}
    volumes:
      - {{ n8n_brain_dir }}:/data
    ports:
      # Loopback only — mount WebDAV via the Caddy route
      # (https://webdav-n8n.<internal_host>) or an SSH tunnel.
      - "127.0.0.1:{{ n8n_webdav_port }}:8888"
{% endif %}

networks:
  default:
    name: backend
    external: true
