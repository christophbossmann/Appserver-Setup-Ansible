# Pull just the docker CLI binary from the official image (no daemon).
FROM docker:cli AS dockercli

FROM python:3.12-slim
COPY --from=dockercli /usr/local/bin/docker /usr/local/bin/docker
RUN pip install --no-cache-dir "fastapi>=0.110" "uvicorn[standard]>=0.29"
WORKDIR /app
COPY app.py /app/app.py
# Listens only on the internal network; never published to the host.
CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "{{ helper_port }}"]
